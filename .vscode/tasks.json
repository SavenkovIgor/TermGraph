{
    "version": "2.0.0",
    "type": "shell",
    "problemMatcher": [],
    "inputs": [
        {
            "id": "preset",
            "type": "pickString",
            "description": "Select the preset:",
            "options": [
                "desktop_dev",
                "desktop_release",
                "wasm_dev",
                "wasm_release"
            ]
        },
        {
            "id": "preview",
            "type": "command",
            "command": "simpleBrowser.show",
            "args": [
                "http://localhost:8000"
            ]
        }
    ],
    "tasks": [
        {
            "label": "Build",
            "detail": "Build the project using the selected preset",
            "command": "./project.py --build --preset ${input:preset}",
            "icon": {
                "id": "tools",
                "color": "terminal.ansiBlue"
            },
            "presentation": {
                "revealProblems": "onProblem",
                "clear": true
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run",
            "detail": "Run the project using the selected preset",
            "command": "./project.py --run --preset ${input:preset}",
            "icon": {
                "id": "play",
                "color": "terminal.ansiGreen"
            }
        },
        {
            "label": "Test",
            "detail": "Test the project using the selected preset",
            "command": "./project.py --test --preset ${input:preset}",
            "icon": {
                "id": "beaker",
                "color":"terminal.ansiMagenta"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "CMake Install",
            "detail": "Run CMake install (make sense only for WASM presets)",
            "command": "./project.py --cmake-install --preset ${input:preset}",
            "dependsOn": [
                "Build"
            ]
        },
        {
            "label": "Clear",
            "detail": "Clear the build dir",
            "command": "./project.py --clear",
            "icon": {
                "id": "trash",
                "color": "terminal.ansiRed"
            }
        },
        {
            "label": "Clear all",
            "detail": "Clear build dir & conan cache",
            "command": "./project.py --clear-all",
            "icon": {
                "id": "trash",
                "color": "terminal.ansiRed"
            }
        },
        {
            "label": "Build and Run",
            "detail": "Build and run the project using the selected preset",
            "dependsOn": [
                "Build",
                "CMake Install",
                "Run"
            ],
            "dependsOrder": "sequence",
            "icon": {
                "id": "run-all",
                "color": "terminal.ansiGreen"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run HTTP Server",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "http.server",
                "--bind",
                "0.0.0.0",
                "--directory",
                "build/${input:preset}/dist",
                "8000"
            ],
            "isBackground": true,
            "dependsOn": [
                "CMake Install"
            ],
            "icon": {
                "id": "server",
                "color": "terminal.ansiCyan"
            }
        },
        {
            "label": "Open Browser",
            "detail": "Open the browser to view the application",
            "command": "echo ${input:preview}",
            "presentation": {
                "reveal": "silent",
                "focus": false
            },
            "icon": {
                "id": "globe",
                "color": "terminal.ansiCyan"
            }
        }
    ]
}
